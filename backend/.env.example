# PNU Student Portal Backend — Environment Variables Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# Express Port Setting (UI vite proxy currently expects 3000)
PORT=3000

# Comma-separated browser origins allowed for CORS (Vite default included)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase — Project Settings → API in https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_public_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_secret_key_here
SUPABASE_JWKS_URL=your_supabase_jwks_well_known_url_here

# Auth — any long random string (keep secret)
JWT_SECRET=change-me-to-a-long-random-string

# Optional — Claude / Anthropic (major recommendations + extracurricular extract)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Optional — extracurricular scrape pipeline (scripts/scrape-notices.mjs, extract-programs.mjs)
# Prefer service-role key so inserts into raw_announcements / extracurricular_program work.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SCRAPE_MAX_PER_SOURCE=20
# SCRAPE_DELAY_MS=400
# EXTRACT_BATCH_SIZE=10
# EXTRACT_MODE=heuristic   # use without Anthropic; set to claude when you have a key

# Optional — Gemini & OpenRouter
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_open_router_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
