# PNU Student Portal Backend — Environment Variables Template
# Copy this file to .env and fill in the values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)

# Express Port Setting (UI vite proxy currently expects 3000)
PORT=3000

# Comma-separated browser origins allowed for CORS (Vite default included)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public URL of the frontend. Password-recovery emails link back here, so it
# must also be allowed under Supabase → Authentication → URL Configuration.
APP_BASE_URL=http://localhost:5173

# Supabase — required (local mock DB is disabled)
# Project Settings → API in https://supabase.com/dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_public_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_secret_key_here
SUPABASE_JWKS_URL=your_supabase_jwks_well_known_url_here

# Auth — REQUIRED. The server refuses to start without it.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change-me-to-a-long-random-string

# Optional — Claude / Anthropic (major recommendations)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Optional — Gemini & OpenRouter
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_open_router_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
