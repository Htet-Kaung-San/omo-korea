# Set to "mock" while backend is not ready, "real" when API is available
VITE_API_MODE=real

# Base URL for real API (used when VITE_API_MODE=real)
# Vite dev proxy forwards /api/* → http://localhost:3000 (see vite.config.ts)
VITE_API_BASE_URL=/api

# Naver Map Client ID — required for Campus Map page
# Get it from https://www.ncloud.com/product/applicationService/maps
VITE_NAVER_MAP_CLIENT_ID=
