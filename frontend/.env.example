# Set to "mock" while backend is not ready, "real" when API is available
VITE_API_MODE=real

# Base URL for real API (used when VITE_API_MODE=real)
# Vite dev proxy forwards /api/* → http://localhost:3000 (see vite.config.ts)
VITE_API_BASE_URL=/api

# Naver Map — use Application Services > Maps Client ID (ncpKeyId)
# Web Service URL in NCP console MUST be host only, e.g. http://localhost (no :5173)
# https://console.ncloud.com/ → Services → Application Services → Maps
VITE_NAVER_MAP_CLIENT_ID=

# Supabase — direct reads + Realtime for community posts feed
# Project Settings → API → URL + anon (publishable) key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
