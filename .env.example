# PNU Student Portal Backend — Environment Variables Template
# Copy this file to '.env' and fill in the values

# Express Port Setting (Default: 5001)
PORT=5001

# Supabase Configurations
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_public_key_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_public_key_here
SUPABASE_SECRET_KEY=your_supabase_service_role_secret_key_here
SUPABASE_JWKS_URL=your_supabase_jwks_well_known_url_here

# AI Model Keys (Gemini & OpenRouter)
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_open_router_api_key_here
DIGITALOCEAN_API_KEY=your_digitalocean_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Session Encryption Secrets
JWT_SECRET=your_jwt_signing_secret_key_here
